                            Grid.Column="0"
                            Margin="{StaticResource Margin8}"
                            VerticalAlignment="Center"
                            Style="{StaticResource ToolbarTextBlock}"
                            Text="{DynamicResource String_TbSettingsAllowLAN}" />
                        <ToggleButton
                            x:Name="togAllowLANConn"
