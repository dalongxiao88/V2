                            x:Name="cmbmux4SboxProtocol"
                            Grid.Row="17"
                            Grid.Column="1"
                            Width="200"
                            Margin="{StaticResource Margin8}"
                            Style="{StaticResource DefComboBox}" />

                        <TextBlock
                            Grid.Row="18"
                            Grid.Column="0"
                            Margin="{StaticResource Margin8}"
