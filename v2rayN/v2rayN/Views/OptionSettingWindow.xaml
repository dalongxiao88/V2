                        <TextBlock
                            Grid.Row="10"
                            Grid.Column="0"
                            Margin="{StaticResource Margin8}"
                            VerticalAlignment="Center"
                            Style="{StaticResource ToolbarTextBlock}"
                            Text="{DynamicResource String_TbSettingsPass}" />
                        <TextBox
                            x:Name="txtpass"
                            Grid.Row="10"
                            Grid.Column="1"
                            Width="200"
                            Margin="{StaticResource Margin8}"
                            Style="{StaticResource DefTextBox}" />

                        <TextBlock
                            Grid.Row="11"
