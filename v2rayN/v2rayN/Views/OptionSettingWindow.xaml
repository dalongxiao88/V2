                            Margin="{StaticResource Margin8}"
                            VerticalAlignment="Center"
                            Style="{StaticResource ToolbarTextBlock}"
                            Text="{DynamicResource String_TbSettingsHysteriaBandwidth}" />

                        <StackPanel
                            Grid.Row="19"
                            Grid.Column="1"
                            Orientation="Horizontal">

                            <TextBox
                                x:Name="txtUpMbps"
                                Width="90"
                                Margin="{StaticResource Margin8}"
                                materialDesign:HintAssist.Hint="Up"
                                Style="{StaticResource DefTextBox}" />
                            <TextBox
                                x:Name="txtDownMbps"
                                Width="90"
                                Margin="{StaticResource Margin8}"
                                materialDesign:HintAssist.Hint="Down"
                                Style="{StaticResource DefTextBox}" />
                        </StackPanel>

                        <TextBlock
                            Grid.Row="20"
                            Grid.Column="0"
                            Margin="{StaticResource Margin8}"
                            VerticalAlignment="Center"
                            Style="{StaticResource ToolbarTextBlock}"
                            Text="{DynamicResource String_TbSettingsEnableFragment}" />
                        <ToggleButton
                            x:Name="togenableFragment"
                            Grid.Row="20"
                            Grid.Column="1"
                            Margin="{StaticResource Margin8}"
                            HorizontalAlignment="Left" />
